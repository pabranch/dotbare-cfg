# Settings for vi mode
set editing-mode vi
set keymap vi
set vi-cmd-mode-string "\1\e[2 q\2"    # Block cursor in command mode
set vi-ins-mode-string "\1\e[6 q\2"    # Bar cursor in insert mode
#set show-mode-in-prompt on


# Unicode support
set meta-flag on
set input-meta on
set output-meta on
set convert-meta off

# Completion behavior
set completion-ignore-case on
set completion-prefix-display-length 2
#set show-all-if-ambiguous on   # this gets annoying if I know what I want next
set show-all-if-unmodified on
set mark-symlinked-directories on
set match-hidden-files off
set page-completions off
set completion-query-items 100
set visible-stats on
set colored-stats on
set skip-completed-text on

# Tab cycles through completions (shift+tab goes backward)
TAB: menu-complete
"\e[Z": menu-complete-backward
set menu-complete-display-prefix on

# Arrow keys search history by prefix
"\e[A": history-search-backward
"\e[B": history-search-forward
"\e[C": forward-char
"\e[D": backward-char
